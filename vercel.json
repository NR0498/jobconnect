{
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets/|favicon.ico).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
  {
    "path": "/api/cron/sync-opportunities",
    "schedule": "0 8 * * *"
  }
]
}
