# App runtime
PORT=3000
NODE_ENV=development

# Required for persisted users, sessions, jobs, and sync logs
DATABASE_URL=postgres://username:password@localhost:5432/jobconnect

# Protect the sync endpoint and support Vercel cron
CRON_SECRET=replace_with_a_long_random_secret

# Optional source-specific credentials
# The Muse works without a key for testing, but a key increases the rate limit.
THE_MUSE_API_KEY=	567bf2536746b044ee6f914056c60c8eb212b64e0010fdfbcba9ad04f7df1417

# Adzuna remains optional if you decide to use it later.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional Ollama integration
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
