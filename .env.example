# App runtime
PORT=3000
NODE_ENV=development

# Required for persisted users, sessions, jobs, and sync logs
DATABASE_URL=

# Protect the sync endpoint and support Vercel cron
CRON_SECRET=

# Optional source-specific credentials
# The Muse works without a key for testing, but a key increases the rate limit.
THE_MUSE_API_KEY=

# Adzuna remains optional if you decide to use it later.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional employer ATS boards. Entries are comma-separated.
# Use token|Display Name when the token is not the desired company name.
GREENHOUSE_BOARDS=
LEVER_SITES=
ASHBY_BOARDS=

# Optional Ollama integration
OLLAMA_BASE_URL=
OLLAMA_MODEL=
