# App runtime
PORT=3000
NODE_ENV=development

# Optional database config
# Only needed if you later connect Drizzle/Postgres-backed persistence.
DATABASE_URL=postgres://username:password@localhost:5432/jobconnect

# Optional Ollama integration
# Enable these only if you have Ollama installed and running locally.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
